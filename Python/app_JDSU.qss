QWidget {
    background-color: #2b2b2b;
    color: #ffffff;
}

QPushButton {
    background-color: #3c3f41;
    border: none;
    padding: 6px;
    border-radius: 5px;
}

QPushButton:hover {
    background-color: #4c5052;
}

QLineEdit {
    background-color: #3c3f41;
    border: 1px solid #555;
    padding: 5px;
    border-radius: 5px;
}

QPushButton, QLabel {
    font-size: 12pt;
    font-family: Microsoft YaHei;
}